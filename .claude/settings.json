{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(make all *)",
      "Bash(./bin/best_matching_serial ../dictionary.txt word)",
      "Bash(./bin/best_matching_parallel ../dictionary.txt word)",
      "Bash(./bin/best_matching_semaphore ../dictionary.txt word)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/carburauto/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": false,
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "theme": "custom:tokyo-night",
  "editorMode": "vim",
  "autoCompactEnabled": false,
  "effort": "low",
  "model": "sonnet"
}
